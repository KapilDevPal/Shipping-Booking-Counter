// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  FRANCHISE_ADMIN
  BRANCH_STAFF
}

enum ShipmentStatus {
  DRAFT
  RATE_CHECKED
  BOOKED
  LABEL_CREATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  EXCEPTION
}

enum PackageType {
  DOCUMENT
  PARCEL
}

enum ShipmentType {
  EXPRESS
  SURFACE
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           UserRole  @default(BRANCH_STAFF)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id])

  franchiseId    String?
  franchise      Franchise? @relation(fields: [franchiseId], references: [id])

  branchId       String?
  branch         Branch?   @relation(fields: [branchId], references: [id])

  shipments      Shipment[]
  refreshTokens  RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Company / Franchise / Branch ────────────────────────────────────────────

model Company {
  id          String      @id @default(cuid())
  name        String
  code        String      @unique
  gstin       String?
  address     String?
  phone       String?
  email       String?
  logoUrl     String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  franchises  Franchise[]
  users       User[]
  wallets     Wallet[]

  @@map("companies")
}

model Franchise {
  id          String    @id @default(cuid())
  name        String
  code        String
  address     String?
  phone       String?
  email       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])

  branches    Branch[]
  users       User[]

  @@unique([companyId, code])
  @@map("franchises")
}

model Branch {
  id           String    @id @default(cuid())
  name         String
  code         String
  address      String?
  city         String?
  state        String?
  pincode      String?
  phone        String?
  email        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  franchiseId  String
  franchise    Franchise @relation(fields: [franchiseId], references: [id])

  users        User[]
  shipments    Shipment[]

  @@map("branches")
}

// ─── Courier Partners ─────────────────────────────────────────────────────────

model CourierPartner {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique  // e.g. "FLIGHTGO", "DHL", "FEDEX"
  logoUrl      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  rates        ShipmentRate[]

  @@map("courier_partners")
}

// ─── Shipments ────────────────────────────────────────────────────────────────

model Shipment {
  id              String         @id @default(cuid())
  referenceNo     String?
  status          ShipmentStatus @default(DRAFT)

  // Package info
  packageType     PackageType    @default(DOCUMENT)
  shipmentType    ShipmentType   @default(EXPRESS)
  weight          Float          // kg
  length          Float?         // cm
  width           Float?         // cm
  height          Float?         // cm
  volumetricWeight Float?        // calculated: L*W*H/5000

  // Recipient
  toCountry       String
  toZipcodeId     String?
  toCity          String?
  toState         String?

  // Sender
  fromCity        String?
  fromState       String?
  fromPincode     String?

  // Options
  shipDate        DateTime?
  signatureRequired Boolean   @default(false)
  specialHandling   Boolean   @default(false)
  insurance         Boolean   @default(false)
  nonStandardGoods  Boolean   @default(false)
  remarks           String?

  // Booking
  awbNo           String?    @unique
  labelUrl        String?
  bookedAt        DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  branchId        String
  branch          Branch     @relation(fields: [branchId], references: [id])

  createdById     String
  createdBy       User       @relation(fields: [createdById], references: [id])

  rates           ShipmentRate[]

  @@map("shipments")
}

model ShipmentRate {
  id              String         @id @default(cuid())
  shipmentId      String
  shipment        Shipment       @relation(fields: [shipmentId], references: [id])

  partnerId       String
  partner         CourierPartner @relation(fields: [partnerId], references: [id])

  serviceCode     String
  serviceName     String
  rate            Float
  tax             Float          @default(0)
  totalAmount     Float
  currency        String         @default("INR")
  transitDays     Int?
  branchName      String?

  isSelected      Boolean        @default(false)
  fetchedAt       DateTime       @default(now())

  @@map("shipment_rates")
}

// ─── Wallet ───────────────────────────────────────────────────────────────────

model Wallet {
  id          String   @id @default(cuid())
  balance     Float    @default(0)
  currency    String   @default("INR")
  companyId   String   @unique
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("wallets")
}
