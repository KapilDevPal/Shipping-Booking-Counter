# Kamal Secrets — DO NOT COMMIT REAL VALUES
# Fill these in locally and run: kamal secrets push

KAMAL_REGISTRY_USERNAME=your_registry_username
KAMAL_REGISTRY_PASSWORD=your_registry_password

# Database
DB_PASSWORD=your_postgres_password
POSTGRES_PASSWORD=your_postgres_password

# JWT
JWT_SECRET=your_very_long_jwt_secret_here
JWT_REFRESH_SECRET=your_very_long_refresh_secret_here

# FlightGo API (from Postman collection — test creds below, swap for prod)
FLIGHTGO_API_URL=https://flightgoexpress.com
FLIGHTGO_API_USER=test
FLIGHTGO_API_PASS=test@#flightgo

# DHL API
DHL_API_KEY=your_dhl_api_key
DHL_API_SECRET=your_dhl_api_secret
